generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String?
  name           String?
  birthDate      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // OAuth
  authProvider     AuthProvider @default(EMAIL)
  authProviderId   String?

  // Subscription
  subscriptionStatus  SubscriptionStatus @default(FREE)
  revenuecatId        String?

  // Progress (synced from mobile)
  completedChapters   Int[]    @default([])
  completedBooks      Int[]    @default([])
  chatMessageCount    Int      @default(0)
  streak              Int      @default(0)
  lastActiveDate      String   @default("")
  graduated           Boolean  @default(false)

  // Rate limiting
  dailyCoachMessages  Int      @default(0)
  lastCoachResetDate  String   @default("")
  dailyVoiceSessions  Int      @default(0)
  lastVoiceResetDate  String   @default("")

  // Hearts economy
  dailyHeartsUsed     Int      @default(0)
  lastHeartsResetDate String   @default("")
  bonusHearts         Int      @default(0)

  // One-time purchases
  hasPdfAccess        Boolean  @default(false)
  hasChapterUnlock    Boolean  @default(false)

  chatMessages        ChatMessage[]

  @@index([authProvider, authProviderId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  userId         String
  role           String   // 'user' | 'assistant'
  content        String
  createdAt      DateTime @default(now())
  conversationId String?
  characterId    String?

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, conversationId, createdAt])
}

enum SubscriptionStatus {
  FREE
  PREMIUM
  PRO
  PRO_PLUS
  EXPIRED
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}
